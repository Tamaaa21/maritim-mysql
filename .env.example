# Database (MySQL)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=your_user
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=bmkg_maritim

# reCAPTCHA - daftar di https://www.google.com/recaptcha/admin
# Pilih reCAPTCHA v2 "I'm not a robot" (Checkbox)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_site_key
RECAPTCHA_SECRET_KEY=your_secret_key

# Session secret untuk admin authentication token (HMAC-SHA256)
# Wajib diganti dengan string random yang panjang di production!
# Contoh: openssl rand -hex 32
TOKEN_SECRET=your_random_secret_here

# BMKG API URL untuk proxy cuaca
BMKG_API_URL=https://api.bmkg.go.id/publik/prakiraan-cuaca?adm4=33.76.01.1001

# Cache TTL untuk BMKG API (ms)
BMKG_CACHE_TTL=600000

# WhatsApp Business Number (international format without +)
NEXT_PUBLIC_WHATSAPP_PHONE=628112562200
